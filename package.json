{
  "name": "arcknights",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "next build && wrangler dev",
    "deploy": "next build && wrangler deploy",
    "scrape": "tsx scripts/scrape-skland.ts",
    "scrape:manifest": "tsx scripts/scrape-skland.ts --from-manifest",
    "kv:upload": "tsx scripts/upload-bundle.ts",
    "kv:upload:local": "tsx scripts/upload-bundle.ts --local",
    "kv:get": "wrangler kv key get --binding=DATA --remote bundle"
  },
  "dependencies": {
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "playwright": "^1.59.1",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
